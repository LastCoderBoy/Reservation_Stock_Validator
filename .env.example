# ========================================
# Environment Variables Template
# ========================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# ========================================
# SPRING PROFILES
# ========================================
# dev  = verbose logging, SQL output, HTTP cookies allowed
# prod = minimal logging, HTTPS cookies only, restricted actuator
SPRING_PROFILES_ACTIVE=prod

# ========================================
# DATABASE CONFIGURATION
# ========================================
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=reservation_db

# ========================================
# JWT CONFIGURATION
# ========================================
# Generate a secure key: openssl rand -base64 64
JWT_SECRET=your_base64_encoded_secret_key_here

# ========================================
# REDIS CONFIGURATION (Cloud - RedisLabs)
# ========================================
REDIS_HOST=your-redis-host.redislabs.com
REDIS_PORT=12345
REDIS_PASSWORD=your_redis_password

# ========================================
# FRONTEND CONFIGURATION
# ========================================
# API URL for frontend to call backend
VITE_API_BASE_URL=http://localhost:8080/api/v1

# ========================================
# PRODUCTION CORS (only needed for prod profile)
# ========================================
# Comma-separated list or single domain
CORS_ALLOWED_ORIGINS=https://yourdomain.com
